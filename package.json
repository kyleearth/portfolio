{
  "name": "kyle-wang-portfolio",
  "version": "1.0.0",
  "private": true,
  "description": "Frontend build scripts for Kyle Wang's portfolio website",
  "repository": {
    "type": "git",
    "url": "https://github.com/kyleearth/portfolio.git"
  },
  "keywords": [
    "jekyll",
    "portfolio",
    "academic"
  ],
  "author": "Kyle Wang",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/kyleearth/portfolio/issues"
  },
  "homepage": "https://kyleearth.github.io/portfolio/",
  "engines": {
    "node": ">= 0.10.0"
  },
  "devDependencies": {
    "npm-run-all": "^1.7.0",
    "onchange": "^2.2.0",
    "uglify-js": "^2.6.1"
  },
  "scripts": {
    "uglify": "uglifyjs assets/js/vendor/jquery/jquery-1.12.4.min.js assets/js/plugins/jquery.fitvids.js assets/js/plugins/jquery.greedy-navigation.js assets/js/plugins/jquery.magnific-popup.js assets/js/plugins/jquery.smooth-scroll.min.js assets/js/plugins/stickyfill.min.js assets/js/_main.js -c -m -o assets/js/main.min.js",
    "watch:js": "onchange \"assets/js/**/*.js\" -e \"assets/js/main.min.js\" -- npm run build:js",
    "build:js": "npm run uglify"
  }
}
